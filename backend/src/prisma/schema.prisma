generator client {
  provider = "prisma-client"
  output   = "../../node_modules/.prisma/client"
}

datasource db {
  provider = "sqlserver"
}

model User {
  id         Int       @id @default(autoincrement())
  name       String    @db.NVarChar(100)
  email      String    @unique @db.NVarChar(100)
  password   String    @db.NVarChar(255)
  phone      String?   @db.NVarChar(20)
  role       String    @default("customer") @db.NVarChar(20)
  avatarUrl  String?   @map("avatar_url") @db.NVarChar(500)
  createdAt  DateTime  @default(now()) @map("created_at")
  updatedAt  DateTime  @updatedAt @map("updated_at")

  bookings   Booking[]
  reviews    Review[]

  @@map("users")
}

model Hotel {
  id          Int       @id @default(autoincrement())
  name        String    @db.NVarChar(200)
  description String?   @db.NVarChar(Max)
  address     String    @db.NVarChar(500)
  city        String    @db.NVarChar(100)
  latitude    Decimal?  @db.Decimal(10, 8)
  longitude   Decimal?  @db.Decimal(11, 8)
  rating      Decimal   @default(0) @db.Decimal(2, 1)
  starRating  Int       @default(3) @map("star_rating")
  imageUrl    String?   @map("image_url") @db.NVarChar(500)
  phone       String?   @db.NVarChar(20)
  email       String?   @db.NVarChar(100)
  isFeatured  Boolean   @default(false) @map("is_featured")
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")

  images      HotelImage[]
  amenities   HotelAmenity[]
  rooms       Room[]
  reviews     Review[]

  @@index([city])
  @@map("hotels")
}

model HotelImage {
  id       Int    @id @default(autoincrement())
  hotelId  Int    @map("hotel_id")
  imageUrl String @map("image_url") @db.NVarChar(500)
  caption  String? @db.NVarChar(200)

  hotel    Hotel  @relation(fields: [hotelId], references: [id], onDelete: Cascade)

  @@map("hotel_images")
}

model Amenity {
  id     Int     @id @default(autoincrement())
  name   String  @db.NVarChar(100)
  icon   String? @db.NVarChar(50)

  hotels HotelAmenity[]

  @@map("amenities")
}

model HotelAmenity {
  hotelId   Int @map("hotel_id")
  amenityId Int @map("amenity_id")

  hotel   Hotel   @relation(fields: [hotelId], references: [id], onDelete: Cascade)
  amenity Amenity @relation(fields: [amenityId], references: [id], onDelete: Cascade)

  @@id([hotelId, amenityId])
  @@map("hotel_amenities")
}

model Room {
  id         Int       @id @default(autoincrement())
  hotelId    Int       @map("hotel_id")
  name       String    @db.NVarChar(100)
  description String?  @db.NVarChar(Max)
  price      Decimal   @db.Decimal(12, 2)
  capacity   Int       @default(2)
  totalRooms Int       @default(1) @map("total_rooms")
  imageUrl   String?   @map("image_url") @db.NVarChar(500)
  status     String    @default("available") @db.NVarChar(20)
  createdAt  DateTime  @default(now()) @map("created_at")
  updatedAt  DateTime  @updatedAt @map("updated_at")

  hotel      Hotel     @relation(fields: [hotelId], references: [id], onDelete: Cascade)
  bookings   Booking[]

  @@index([hotelId])
  @@map("rooms")
}

model Booking {
  id             Int       @id @default(autoincrement())
  userId         Int?      @map("user_id")
  roomId         Int       @map("room_id")
  checkIn        DateTime  @map("check_in") @db.Date
  checkOut       DateTime  @map("check_out") @db.Date
  numRooms       Int       @default(1) @map("num_rooms")
  totalPrice     Decimal   @map("total_price") @db.Decimal(12, 2)
  status         String    @default("pending") @db.NVarChar(20)
  guestName      String    @map("guest_name") @db.NVarChar(100)
  guestEmail     String    @map("guest_email") @db.NVarChar(100)
  guestPhone     String?   @map("guest_phone") @db.NVarChar(20)
  paymentMethod  String    @default("credit_card") @map("payment_method") @db.NVarChar(20)
  paymentStatus  String    @default("pending") @map("payment_status") @db.NVarChar(20)
  specialRequests String?  @map("special_requests") @db.NVarChar(Max)
  createdAt      DateTime  @default(now()) @map("created_at")
  updatedAt      DateTime  @updatedAt @map("updated_at")

  user           User?     @relation(fields: [userId], references: [id], onDelete: SetNull)
  room           Room      @relation(fields: [roomId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([roomId])
  @@index([checkIn, checkOut])
  @@map("bookings")
}

model Review {
  id        Int      @id @default(autoincrement())
  userId    Int      @map("user_id")
  hotelId   Int      @map("hotel_id")
  rating    Int
  comment   String?  @db.NVarChar(Max)
  createdAt DateTime @default(now()) @map("created_at")

  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  hotel     Hotel    @relation(fields: [hotelId], references: [id], onDelete: NoAction)

  @@index([hotelId])
  @@map("reviews")
}
